{
  "functions": {
    "app/api/upload/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/video/generate/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/dashboard/route.ts": {
      "maxDuration": 30
    },
    "app/api/events/[eventId]/download/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
